# === Application ===
PORT=5181
NODE_ENV=production

# === MSSQL Server ===
MSSQL_HOST=192.168.x.x
MSSQL_USER=your_db_user
MSSQL_PASSWORD=your_db_password
MSSQL_DATABASE=ASSET_MANAGEMENT
MSSQL_PORT=1433

# === Network Share (Windows) ===
# Note: For Docker Linux, mapping a Windows share requires either:
# 1. Mounting the CIFS share directly to the container via docker-compose volumes
# 2. Or using a Windows container
SHARE_BASE_PATH=Y:\AssetManagement_Files
SHARE_USER=your_share_user
SHARE_PASSWORD=your_share_password

# === Security ===
JWT_SECRET=generate-a-strong-random-string-here
PASSWORD_SALT=generate-a-salt-string-here
